rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Users collection
    match /users/{userId} {
      // Note: You might want to secure this to 'request.auth.uid == userId' later!
      allow read, write: if request.auth != null;
    }

    // 2. Top-level Clients collection (if you are also storing clients here)
    match /clients/{clientId} {
      allow read, write: if request.auth != null;
    }
  
    match /users/{userId}/clients/{clientId} {
      // Allow the user to read/write ONLY if their Auth UID matches the document path UID
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  } // <--- This is the final closing brace for the documents block
}